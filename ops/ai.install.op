#!/bin/bash

RUN set -e

RUN if [ "$EUID" -ne 0 ]; then
  #echo "Please run with sudo"
  exit
fi

#echo "=============================="
#echo "AI SERVER INSTALLER"
#echo "=============================="

RUN AI_API_KEY="$$ai_api_key"

RUN THREADS=$(nproc)

#echo "Detected CPU threads: $THREADS"

#echo "=============================="
#echo "Checking AVX support"
#echo "=============================="

RUN if grep -q avx /proc/cpuinfo; then
    #echo "AVX supported"
else
    #echo "WARNING: CPU has no AVX. Performance will be slower."
fi

#echo "=============================="
#echo "Updating system"
#echo "=============================="

RUN apt update
RUN apt upgrade -y

#echo "=============================="
#echo "Installing dependencies"
#echo "=============================="

RUN apt install -y curl docker.io nginx git ufw

RUN systemctl enable docker
RUN systemctl start docker

#echo "=============================="
#echo "Installing Ollama"
#echo "=============================="

RUN curl -fsSL https://ollama.com/install.sh | sh

RUN mkdir -p /etc/systemd/system/ollama.service.d

RUN printf '%s\n' \
'[Service]' \
'Environment="OLLAMA_NUM_THREADS='"$THREADS"'"' \
'Environment="OLLAMA_KEEP_ALIVE=5m"' \
'Environment="OLLAMA_MAX_LOADED_MODELS=1"' \
> /etc/systemd/system/ollama.service.d/override.conf

RUN systemctl daemon-reload
RUN systemctl restart ollama

RUN sleep 8

#echo "=============================="
#echo "Downloading model phi3-mini"
#echo "=============================="

RUN ollama pull phi3:mini

#echo "=============================="
#echo "Installing Open WebUI"
#echo "=============================="

RUN docker rm -f open-webui || true

RUN docker run -d \
--name open-webui \
--network=host \
--e PORT=3000 \
--e OLLAMA_BASE_URL=http://127.0.0.1:11434 \
--v open-webui:/app/backend/data \
--restart always \
ghcr.io/open-webui/open-webui:main

#echo "=============================="
#echo "Configuring Nginx API gateway"
#echo "=============================="

RUN printf '%s\n' \
'server {' \
'    listen 80;' \
'' \
'    location /ollama/ {' \
'' \
'        if ($http_authorization != "Bearer $$ai_api_key") {' \
'            return 401;' \
'        }' \
'' \
'        proxy_pass http://127.0.0.1:11434/;' \
'        proxy_http_version 1.1;' \
'' \
'        proxy_set_header Host $host;' \
'        proxy_set_header X-Real-IP $remote_addr;' \
'    }' \
'}' \
> /etc/nginx/sites-available/ollama

RUN ln -s /etc/nginx/sites-available/ollama /etc/nginx/sites-enabled/ollama || true
RUN rm -f /etc/nginx/sites-enabled/default

RUN systemctl restart nginx

#echo "=============================="
#echo "Configuring Firewall"
#echo "=============================="

RUN ufw allow 22
RUN ufw allow 80
RUN ufw allow 3000
RUN ufw --force enable

RUN IP=$(curl -s ifconfig.me)

#echo ""
#echo "=============================="
#echo "INSTALLATION COMPLETE"
#echo "=============================="
#echo ""
#echo "Web UI:"
#echo "http://$IP:3000"
#echo ""
#echo "API endpoint:"
#echo "http://$IP/ollama/api/generate"
#echo ""
#echo "API KEY:"
#echo "$$ai_api_key"
#echo ""
#echo "Example request:"
#echo ""
#echo "curl http://$IP/ollama/api/generate \\"
#echo "-H \"Authorization: Bearer $$ai_api_key\" \\"
#echo "-d '{\"model\":\"phi3:mini\",\"prompt\":\"Write a cold email\"}'"
#echo ""